# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
APP_NAME=MindCare AI
APP_ENV=development
SECRET_KEY=change-me-in-production
DEBUG=true

# ─────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-2024-08-06
OPENAI_MODEL_DEV=gpt-4o-mini

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
POSTGRES_DB=mindcare
POSTGRES_USER=mindcare
POSTGRES_PASSWORD=mindcare_dev_password
DATABASE_URL=postgresql+asyncpg://mindcare:mindcare_dev_password@postgres:5432/mindcare

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─────────────────────────────────────────
# Security
# ─────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
ENCRYPTION_KEY=change-me-32-byte-aes-key-here!!

# ─────────────────────────────────────────
# Safety / Crisis Thresholds
# ─────────────────────────────────────────
CRISIS_RISK_THRESHOLD=7
EXPERT_REVIEW_THRESHOLD=6

# ─────────────────────────────────────────
# Monitoring
# ─────────────────────────────────────────
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=false
